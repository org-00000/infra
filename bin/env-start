#!/usr/bin/env bash

# [[ref:6612d34b-e5e7-4d42-b1bf-d73bb1ed9906][Specification]]
# [[id:b80c22c9-2eed-4eea-a469-136e7666ea96]]

set -euo pipefail
IFS=$'\n\t'
[[ "${VERBOSE:-false}" == "true" ]] && {
  export VERBOSE
  set -x
}

if [[ -v GUIX_ENVIRONMENT ]]; then
  echo "INFO | The development environment is active."
  exit 0
fi

# If a command named cmd is not available; then: write an error message to stdout and
# exit.
function _cmd_check() {
  local name="$1"
  if ! command -v "$name" &>/dev/null; then
    echo "ERROR | $name is not available"
    exit 1
  fi
}
_cmd_check git
_cmd_check ssh-add
_cmd_check guix

# TODO(55c8): add other checks. For instance, KVM and QEMU should be available

# The script current directory is set to the root of the project and environment
# variables are loaded (see: [[ref:c86dd881-e3c4-4f73-9084-b80a02a7e581][profile]]).
ROOT="$(git rev-parse --show-toplevel)"
ETC="$ROOT/etc"
ENV="$ETC/bash-dev-profile"
source "$ENV"

if ! ssh-add -l &>/dev/null; then
  echo "WARNING | The SSH agent is necessary to connect to a VPS"
fi

# If the host has not signing key; then: build it. This signature should be accepted
# by the receiving VPS in order to deploy builds. See:
# https://guix.gnu.org/manual/devel/en/html_node/Invoking-guix-archive.html#index-signing_002c-archives
if [[ ! -f "$HOST_ETC_GUIX/signing-key.pub" ]]; then
  sudo -k guix archive --generate-key
fi

# Ensure that relevant files are shared between the host and the guest.
if [[ ! -d "$CLAUDE" ]]; then
  mkdir -vp "$CLAUDE"
fi
if [[ ! -e "$CLAUDE_CONFIG" ]]; then
  touch "$CLAUDE_CONFIG"
fi

# Ensure that relevant files are shared between the host and the guest.
mkdir -p "$NPM_ROOT"

# [[id:21b4b68a-aef7-44e5-ac79-a26a7100cbdd]]
# If SSL certificates are placed in a known directory, then OTP can use them.
# see:
# https://github.com/erlang/otp/blob/f1944a13c33f7214d498270ed2f09f39152d6952/lib/public_key/src/pubkey_os_cacerts.erl#L221
# In order to use SSH from within the container and using the host keys,
# SSH_AUTH_SOCK is shared.
guix time-machine -C "$CHANNELS" -- shell \
  -C \
  -m "$MANIFEST" \
  -N \
  -W \
  --expose="$HOST_ETC_GUIX" \
  -E ^SSH_AUTH_SOCK \
  --share="${SSH_AUTH_SOCK:-}" \
  --share=/tmp=/host/tmp \
  -S /usr/bin=bin \
  -S /lib64=lib \
  -S /etc/ssl/certs/ca-certificates.crt=etc/ssl/certs/ca-certificates.crt \
  -E ^TERM \
  --expose=/usr/share/bash-completion=/host/usr/share/bash-completion \
  -E '^WAYLAND_DISPLAY$' \
  -E '^XDG_RUNTIME_DIR$' \
  --expose="$XDG_RUNTIME_DIR" \
  --share="/run/user/$UID" \
  --share="$CLAUDE" \
  --share="$NPM_ROOT"="$HOME/.npm-global" \
  --share="$CLAUDE_CONFIG" \
  -- bash --init-file "$DEV_SESSION" -i

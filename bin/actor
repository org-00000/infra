#!/usr/bin/env bash

# [[ref:91c7ba77-bb5c-482a-93d2-3e1466a01e22][Specification]]
# [[id:119d5773-63cc-4add-b4d2-d5001b367677]]

set -euo pipefail
IFS=$'\n\t'

MSG="${0##*/}"

function inside_container_check() {
  if [[ ! -v GUIX_ENVIRONMENT ]]; then
    echo "ERROR | should be inside the container"
    exit 1
  fi
}

function outside_container_check() {
  if [[ -v GUIX_ENVIRONMENT ]]; then
    echo "ERROR | should be outside the container"
    exit 1
  fi
}

function image_mk() {
  inside_container_check

  # /path/to/os/name.scm
  local os_path
  os_path="$(realpath "$1")"

  # /path/to/image/name.qcow2
  local image_type="qcow2"
  local image_path="${os_path##*/}"
  image_path="${image_path%.*}"
  image_path="$IMAGE/$image_path.$image_type"
  local image_hash=""
  if [[ -f "$image_path" ]]; then
    image_hash=$(sha256sum "$image_path" | cut -d' ' -f1)
  fi

  # os_path → image_path
  local store_path=""
  local store_hash=""
  store_path="$(guix time-machine -C "$CHANNELS" -- system image -t "$image_type" --image-size=20G "$os_path")"
  store_hash=$(sha256sum "$store_path" | cut -d' ' -f1)

  # Compare hashes – skip copy if identical
  if [[ "$store_hash" != "$image_hash" ]]; then
    cp -f "$store_path" "$image_path"
    chmod +w "$image_path"
  fi

  echo "$image_path"
}

host_key() {
  # 127.0.0.1
  local host="$1"
  # 2222
  local port="$2"
  local key=""

  key=$(ssh-keyscan -p "$port" -t ed25519 "$host" 2>/dev/null |
    rg '.*(ssh-ed25519.*)' --trim -r '$1' |
    head -n 1)

  if [[ -n "$key" ]]; then
    echo "$key"
  else
    echo "ERROR | Failed to retrieve ssh-ed25519 host key for '$host'" >&2
    return 1
  fi
}

if [[ "$MSG" == ",install-node-binaries" ]]; then
  # [[ref:220179a9-aa3e-490d-ab6e-3ef02d759bee][Specification]]
  inside_container_check
  npm install -g @anthropic-ai/claude-code \
    bash-language-server

elif [[ "$MSG" == ",frontend-fetch" ]]; then
  # [[ref:c6dfad7d-72df-4788-ac6f-97c297f6df94][Specification]]
  # [[id:d53d5526-93ba-4a87-b58e-e67d32893f92]]
  inside_container_check
  FRONTEND_REPO="$1"
  if [[ -d "$FRONTEND" ]]; then
    CURRENT_URL="$(git -C "$FRONTEND" remote get-url origin 2>/dev/null)"
    if [[ "$CURRENT_URL" != "$FRONTEND_REPO" ]]; then
      read -r -p "Replace '$FRONTEND' (cloned from '$CURRENT_URL') with '$FRONTEND_REPO'? [y/N] " REPLY
      [[ "$REPLY" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
      rm -rf "$FRONTEND"
      git clone "$FRONTEND_REPO" "$FRONTEND"
    else
      git -C "$FRONTEND" pull
    fi
  else
    git clone "$FRONTEND_REPO" "$FRONTEND"
  fi
  npm --prefix "$FRONTEND" install

elif [[ "$MSG" == ",frontend-dist-mk" ]]; then
  # [[ref:5357e215-36ce-4592-839d-7032b21b5b62][Specification]]
  inside_container_check
  BACKEND_URL="$1"
  cd "$FRONTEND"
  export VITE_API_BASE_URL="$BACKEND_URL"
  npm run build

elif [[ "$MSG" == ",db-start" ]]; then
  # [[ref:87cf68ef-3011-46ad-8e8a-84d06cbbcc3c][Specification]]
  # [[id:092b1e5e-34ff-49fd-b292-4b3b2fa81934]]

  inside_container_check

  mkdir -p "$DB_RUN"
  chmod 700 "$DB_RUN"

  if pg_ctl -D "$DB_DATA" status >/dev/null 2>&1; then
    echo "PostgreSQL is already running. Stopping it first..."
    pg_ctl -D "$DB_DATA" stop -m fast
    sleep 1
  fi

  if [[ ! -e "$DB_VERSION" ]]; then
    initdb -D "$DB_DATA" --locale=C.UTF-8 --encoding=UTF8 --username=postgres
  fi

  cat <<'EOF' >"$DB_HBA"
# TYPE  DATABASE  USER  ADDRESS  METHOD
local   all       all            peer  map=appmap
EOF
  cat <<EOF >"$DB_IDENT"
# MAPNAME  SYSTEM-USERNAME PG-USERNAME
appmap     $USER           postgres
appmap     root            postgres
EOF
  pg_ctl -D "$DB_DATA" -l "$DB_LOG" -o "-k $DB_RUN -p $DB_PORT -c listen_addresses=''" start
  # test the connection.
  psql -h "$DB_RUN" -U postgres -c "\q"

elif [[ "$MSG" == ",backend-deps-fetch" ]]; then
  # [[ref:97be4e51-e157-424c-9ada-5a77ef7a6274][Specification]]
  inside_container_check
  cd "$BACKEND"
  mix local.hex --force --if-missing
  mix deps.get

elif [[ "$MSG" == ",backend-db-migrate" ]]; then
  # [[ref:e441c65a-8849-44d4-a4ba-343fbc1f0ada][Specification]]
  inside_container_check
  cd "$BACKEND"
  mix ecto.create
  mix ecto.migrate

elif [[ "$MSG" == ",backend-iex-start" ]]; then
  # [[ref:56e0e558-5ea0-4ca3-9f75-0129149aa702][Specification]]
  inside_container_check
  ,backend-deps-fetch
  ,db-start
  ,backend-db-migrate
  cd "$BACKEND"
  iex --dbg pry -S mix phx.server

elif [[ "$MSG" == ",contract-checker-start" ]]; then
  # [[id:e1f2a3b4-c5d6-7890-ef12-345678901234]]
  inside_container_check
  cd "$CONTRACT_CHECKER"
  mix deps.get
  if [[ -f "$CONTRACT_CHECKER_PID" ]]; then
    kill -- -"$(cat "$CONTRACT_CHECKER_PID")" 2>/dev/null || kill "$(cat "$CONTRACT_CHECKER_PID")" 2>/dev/null || true
    rm -f "$CONTRACT_CHECKER_PID"
    sleep 2
  fi
  BACKEND_URL="http://localhost:4000" \
  CONTRACT_CHECKER_PORT="$CONTRACT_CHECKER_PORT" \
  MIX_ENV=dev \
    setsid mix phx.server &>/dev/null &
  echo $! > "$CONTRACT_CHECKER_PID"
  echo "INFO | Contract checker started on port $CONTRACT_CHECKER_PORT (pid $(cat "$CONTRACT_CHECKER_PID"))"

elif [[ "$MSG" == ",app-start" ]]; then
  # [[ref:3a2b4174-ea2e-4ed2-97b3-23b562be59a2][Specification]]
  # [[id:51ade351-7413-4355-9e56-55d1166380b5]]
  inside_container_check
  ,contract-checker-start
  ,frontend-dist-mk "http://localhost:${CONTRACT_CHECKER_PORT}/api"
  cp -r "$FRONTEND_DIST/." "$BACKEND/priv/static/"
  ,backend-iex-start

elif [[ "$MSG" == ",image-init-build" ]]; then
  # [[ref:ead19c86-d75c-45d6-8aa7-00cea2f049b0][Specification]]
  inside_container_check
  image_mk "$OS_PATH_INIT"

elif [[ "$MSG" == ",vm-init-start" ]]; then
  # [[ref:518d54c7-3288-4b71-a951-e612dfab5cb2][Specification]]

  outside_container_check

  ROOT="$(git rev-parse --show-toplevel)"
  source "$ROOT/etc/bash-dev-profile"

  if [[ ! -e "$IMAGE_INIT" ]]; then
    echo "ERROR | Execute ,image-init-build within the container first"
    exit 1
  fi

  # [[ref:9952e0a0-6fe0-40cb-97fd-1d56074ab2a5][Specification]]
  mkdir -p "$VM_RUN"
  systemctl --user stop "$VM_UNIT" 2>/dev/null || true
  systemctl --user reset-failed "$VM_UNIT" 2>/dev/null || true
  systemd-run --user --unit="$VM_UNIT" --collect -- \
    qemu-system-x86_64 \
    -machine type=q35,accel=kvm \
    -cpu host -m 8192 -smp cores=4 \
    -snapshot \
    -blockdev driver=qcow2,node-name=disk0,file.driver=file,file.filename="$IMAGE_INIT" \
    -device virtio-blk-pci,drive=disk0 \
    -netdev user,id=net0,hostfwd=tcp::"$VM_PORT_SSH"-:22,hostfwd=tcp::"$VM_PORT_HTTP"-:80,hostfwd=tcp::"$VM_PORT_HTTPS"-:443 \
    -device virtio-net-pci,netdev=net0 \
    -chardev socket,id=mon,path="$VM_SOCKET",server=on,wait=off \
    -mon chardev=mon,mode=control

  systemctl --user --no-pager status "$VM_UNIT"

  echo "INFO | Waiting for VM sshd..."
  for i in $(seq 1 20); do
    echo "INFO | Attempt $i"
    ssh-keyscan -p "$VM_PORT_SSH" -T 1 127.0.0.1 2>/dev/null | grep -q ssh && break
    sleep 1
    if [[ $i -eq 20 ]]; then
      echo "ERROR | VM sshd did not start within 20 seconds" >&2
      exit 1
    fi
  done

  ssh -p "$VM_PORT_SSH" -i "$KEY_SSH_PUB" \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    root@localhost

elif [[ "$MSG" == ",vm-deploy" ]]; then
  # [[ref:62d66eb4-c006-4f3b-86a0-1675191325cb][Specification]]

  inside_container_check

  OS_NAME="$1"
  export OS_PATH="$OS/$OS_NAME.scm"
  if [[ ! -f "$OS_PATH" ]]; then
    echo "ERROR | OS_NAME not found in OS. OS_NAME: $OS_NAME. OS_PATH: $OS_PATH"
    exit 1
  fi
  export HOST_KEY=""
  HOST_KEY="$(host_key 127.0.0.1 "$VM_PORT_SSH")"
  export HOST_PORT_SSH="$VM_PORT_SSH"
  guix time-machine -C "$CHANNELS" -- deploy "$DEPLOY_VM"

elif [[ "$MSG" == ",ca-build" ]]; then
  # [[ref:bdfdc0d0-6b2a-45a5-b4ca-17b224087d68][Specification]]

  inside_container_check

  mkdir -p "$CERTS"

  # 1. Create local CA key + self-signed CA cert
  openssl genrsa -out "$CERTS/ca-key.pem" 4096
  openssl req -new -x509 -days 3650 -key "$CERTS/ca-key.pem" \
    -subj "/CN=clocks-dev-CA" \
    -out "$CERTS/ca-cert.pem"

  # 2. Create leaf key + CSR
  openssl genrsa -out "$CERTS/dev-key.pem" 2048
  openssl req -new -key "$CERTS/dev-key.pem" \
    -subj "/CN=localhost" \
    -out "$CERTS/dev-csr.pem"

  # 3. Sign the leaf cert with your CA
  #    SAN is mandatory — Chrome ignores CN for hostname validation since 2017
  cat >"$CERTS/dev-ext.cnf" <<EOF
subjectAltName=DNS:localhost,IP:127.0.0.1
basicConstraints=CA:FALSE
keyUsage=digitalSignature,keyEncipherment
extendedKeyUsage=serverAuth
EOF

  openssl x509 -req -days 825 -in "$CERTS/dev-csr.pem" \
    -CA "$CERTS/ca-cert.pem" -CAkey "$CERTS/ca-key.pem" -CAcreateserial \
    -extfile "$CERTS/dev-ext.cnf" \
    -out "$CERTS/dev-cert.pem"

  certutil -d sql:"$HOME"/.pki/nssdb -A \
    -n "clocks-dev-CA" \
    -t "CT,," \
    -i "$CERTS/ca-cert.pem"

elif [[ "$MSG" == ",synchronize-with-upstream" ]]; then
  # [[ref:c5d59ff9-cc78-4f98-a7f6-22d19c39caff][Specification]]
  # [[id:61e5914d-eb8d-46cf-8b7c-31b68079c83e]]

  inside_container_check

  force="false"
  if [[ "${1:-}" == "-f" ]]; then
    force="true"
  fi

  if [[ "$force" == "false" ]]; then
    if [[ -n "$(git status --porcelain)" ]]; then
      echo "ERROR | The current directory is not clean"
      git status
      exit 1
    fi
    echo "WARNING | the objective is to have an exact copy of upstream"
    echo "WARNING | this operation will delete any local commits"
    echo "WARNING | as well as on origin/master that are not on upstream/master"
    echo "WARNING | you may want to save your work in a git stash or another branch"
    read -r -p "Are you sure you want to continue? [y/N] " reply
    case "$reply" in
    [Yy]*) ;;
    *)
      echo "Aborted."
      exit 1
      ;;
    esac
    echo "INFO | You may remove this warning using the -f flag"
  fi

  git fetch upstream
  git checkout master
  git reset --hard upstream/master
  git push --force-with-lease origin master

  echo "INFO | DONE: Your local master and origin/master are now exact copy of upstream/master."

elif [[ "$MSG" == ",find-references" ]]; then
  # [[ref:e307bf91-92a9-4c32-8a1e-b779733fb0f2][Specification]]
  inside_container_check
  UUID="$1"
  rg --with-filename --line-number "\[\[ref:$UUID" "$ROOT" || true

elif [[ "$MSG" == ",find-identifiers" ]]; then
  # [[ref:95fd3870-a36d-491b-9273-f578a5ea5d12][Specification]]
  inside_container_check
  UUID="$1"
  rg --with-filename --line-number "\[\[id:$UUID" "$ROOT" || true

elif [[ "$MSG" == ",todos" ]]; then
  # [[ref:a3f2c1d8-7e4b-4f9a-b6c5-2d1e8f3a5b9c][Specification]]

  inside_container_check

  rg --with-filename --line-number 'TODO' "$ROOT"

else
  echo "Unexpected message: $MSG"
  exit 1
fi

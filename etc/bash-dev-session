# [[ref:e529b076-4540-4c26-97f9-d42e4a2ef30e][Specification]]
# [[id:7cab5b80-5358-4093-b9fa-9d23665ab64a]]

if [[ ! -v GUIX_ENVIRONMENT ]]; then
  echo "ERROR | Not in the environment"
  exit 1
fi

ROOT="$(git rev-parse --show-toplevel)"
source $ROOT/etc/bash-dev-profile

alias ls='ls -p --color=auto'
alias ll='ls -l'
alias emacs="$EDITOR"

PS1='\u@\h \w${GUIX_ENVIRONMENT:+ [env]}\$ '

shopt -s checkwinsize

if ! shopt -oq posix; then
  if [ -f /host/usr/share/bash-completion/bash_completion ]; then
    . /host/usr/share/bash-completion/bash_completion
  fi
fi

export PS1='${debian_chroot:+($debian_chroot)}\[\033[01;31m\]\u@\h\[\033[00m\]:\[\033[01;36m\]\W\[\033[00m\]\$ '

if [ -n "$GUIX_ENVIRONMENT" ]; then
  if [[ $PS1 =~ (.*)"\\$" ]]; then
    PS1="${BASH_REMATCH[1]} [env]\\\$ "
  fi
fi

# Only one Bash history.
shopt -s histappend
HISTSIZE=10000
HISTFILESIZE=10000
HISTCONTROL=ignoredups:ignorespace
HISTTIMEFORMAT="%F %T "

# Load fonts in case a graphical application is started.
fc-cache -r

# Ensure GitHub host key is trusted so SSH doesn't prompt.
mkdir -p ~/.ssh && chmod 700 ~/.ssh
ssh-keygen -F github.com &>/dev/null || ssh-keyscan -t ed25519 github.com >>~/.ssh/known_hosts 2>/dev/null

# Install node binaries
npm config delete prefix
npm config set prefix ~/.npm-global
,install-node-binaries
export PATH="$PATH:$HOME/.npm-global/bin"

# Fetch Elixir language server if needed
if [[ ! -f "$EXS_LS" ]]; then
  mkdir -vp "${EXS_LS%/*}"
  pushd "${EXS_LS%/*}"
  URL="https://github.com/elixir-lsp/elixir-ls/releases/download/v0.30.0/elixir-ls-v0.30.0.zip"
  wget "$URL"
  unzip "${URL##*/}"
  rm *.zip *.bat
  if [[ ! -f "$EXS_LS" ]]; then
    echo "ERROR | could not build Elixir language server. EXS_LS: $EXS_LS"
    exit 1
  fi
  popd
fi

$EDITOR "$README" &

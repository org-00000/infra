# We check that all necessary commands are available, else an error is raised.
function _cmd_check() {
  local name="$1"
  if ! command -v "$name" &>/dev/null; then
    echo "ERROR | $name is not available"
    exit 1
  fi
}
_cmd_check git
_cmd_check gpg

##########
# Locale #
##########

# We prefer standard uniform conventions.
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

########
# Root #
########

# The set of necessary environment variable is defined.
ROOT="$(git rev-parse --show-toplevel)"
export ROOT
export README="$ROOT/README.org"

# Stores various configuration files.
export ETC="$ROOT/etc"

# [[ref:c67a176b-59c5-4439-82ad-619652648941][Specification]]
export CHANNELS="$ETC/channels.scm"

# [[ref:f37c9e20-2ccb-4f68-858f-df3068260078][Specification]]
export MANIFEST="$ETC/manifest.scm"

# [[ref:c86dd881-e3c4-4f73-9084-b80a02a7e581][Specification]]
export DEV_PROFILE="$ETC/bash-dev-profile"

# [[ref:e529b076-4540-4c26-97f9-d42e4a2ef30e][Specification]]
export DEV_SESSION="$ETC/bash-dev-session"

# Stores this project binaries
export BIN="$ROOT/bin"

########
# PATH #
########

# Make the project binaries available from PATH
export PATH="$PATH:$BIN"

###########
# Secrets #
###########

# Secret environment variables
export XAI_API_KEY=sk-000000
export SECRET_KEY_BASE=""

# Read secret values like API keys within the container. In addition from being encrypted,
# this file should be ignored by Git. this file should overwrite the secret environment
# variables values.
export SECRET="$ETC/secret.gpg"
if [[ -v GUIX_ENVIRONMENT ]]; then
  if [[ -f "$SECRET" ]]; then
    set +xv
    set -a
    eval "$(gpg --quiet --batch --yes --decrypt "$SECRET" 2>/dev/null)"
    set +a
  else
    echo "INFO | SECRET file does not exist. Using default values. SECRET: $SECRET"
  fi
fi

########
# Guix #
########

# https://guix.gnu.org/manual/devel/en/html_node/Invoking-guix-archive.html#index-signing_002c-archives
export HOST_ETC_GUIX="/etc/guix"

##########
# Editor #
##########

export EMACSD="$ROOT/emacs.d"
export EDITOR="emacs --init-dir $EMACSD"

############
# Frontend #
############

# [[ref:834f11b4-dcdf-46c2-8472-15884c46ed98][Specification]]
export FRONTEND="$ROOT/frontend"

# [[ref:e58ffb29-988b-4423-a5d7-2d5c41b58ff1][Specification]]
export FRONTEND_OPENAPI="$FRONTEND/openapi.yaml"

# [[ref:985496c0-8e69-4545-9dc2-e9c830e02581][Specification]]
export FRONTEND_DIST="$FRONTEND/dist"

###########
# Backend #
###########

# [[ref:9803cae7-58dd-496c-ba6b-685afca2271c][Specification]]
export BACKEND="$ROOT/backend"

# [[ref:3c58dca0-c23f-433c-aad4-a1c488a11146][Specification]]
export BACKEND_DIST="$BACKEND/_build/prod/rel"

# [[ref:14896dea-bad3-45d9-86d5-55aa0be89f90][Specification]]
export MIX_ENV="dev"

############
# Database #
############

export DB="$ROOT/_postgresql"
export DB_DATA="$DB/data"
export DB_LOG="$DB/postgres.log"
export DB_VERSION="$DB_DATA/PG_VERSION"
export DB_HBA="$DB_DATA/pg_hba.conf"
export DB_IDENT="$DB_DATA/pg_ident.conf"
export DB_RUN="$DB/run"
export DB_PORT=5432

#######
# Key #
#######

export KEY_SSH_PUB="$ETC/dev-key.pub"
export KEY_STORE="$HOST_ETC_GUIX/signing-key.pub"

######
# OS #
######

export OS="$ROOT/os"
export OS_PATH_INIT="$OS/init.scm"

#########
# Image #
#########

export IMAGE="$ROOT/image"
export IMAGE_INIT="$IMAGE/init.qcow2"

####################
# SSL Certificates #
####################

export CERTS="$ROOT/certs"
export CERTS_LOCAL_PUB="$CERTS/dev-cert.pem"
export CERTS_LOCAL_PRV="$CERTS/dev-key.pem"

######
# VM #
######

export VM="$ROOT/vm"
export VM_RUN="$VM/run"
export VM_SOCKET="$VM_RUN/vm.sock"
export VM_UNIT="vm.service"
export VM_PORT_SSH=2222
export VM_PORT_HTTP=8080
export VM_PORT_HTTPS=8443
export VM_ROOT_KEY="$KEY_SSH_PUB"

##############
# Deployment #
##############

export DEPLOY="$ROOT/deployment"
export DEPLOY_VM="$DEPLOY/vm.scm"

###############
# Application #
###############

export APP_NAME="application"
export APP_VERSION="0.1.0"
export APP_DIST="$BACKEND_DIST"
export APP_HOST_NAME="localhost"
export APP_HOST_ROOT_KEY="$KEY_SSH_PUB"
export APP_HOST_CERT_PUB="$CERTS_LOCAL_PUB"
export APP_HOST_CERT_PRV="$CERTS_LOCAL_PRV"
export APP_STORE_KEY="$KEY_STORE"

#######
# NPM #
#######

NPM="$ROOT/npm"

# We want to persist installations accross container restarts but avoid to pollute host,
# so we mount NPM global using this directory.
NPM_ROOT="$NPM/npm-global"

##########
# Claude #
##########

CLAUDE="$HOME/.claude"
CLAUDE_CONFIG="$HOME/.claude.json"
